# ============================================
# Community Platform - Web (.env.local)
# ============================================

# --- API ---
# REST API のベース URL（末尾に /api を含める）
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# WebSocket のベース URL（/api なし。省略時は NEXT_PUBLIC_API_URL から自動導出）
# 本番では wss:// を指定すること
# NEXT_PUBLIC_WS_URL=ws://localhost:4000

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Sentry ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
