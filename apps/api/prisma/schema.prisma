generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// Phase 1: 認証・コアシェル
// ============================================================

// --- Enums ---

enum UserRole {
  owner
  admin
  moderator
  member
}

enum UserStatus {
  active
  suspended
  withdrawn
}

enum SocialProvider {
  google
  apple
}

enum LoginStatus {
  success
  failure
}

enum FeatureCategory {
  common
  optional
}

enum SettingValueType {
  string
  integer
  boolean
  json
}

enum FileCategory {
  avatar
  image
  video
  document
  general
}

enum Gender {
  male
  female
  other
  prefer_not_to_say
}

enum LanguageProficiency {
  beginner
  intermediate
  advanced
  native
}

enum PublicStatus {
  public
  private
}

// --- Models ---

model User {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email            String    @unique @db.VarChar(255)
  passwordHash     String    @map("password_hash") @db.VarChar(255)
  name             String    @db.VarChar(100)
  role             UserRole  @default(member)
  status           UserStatus @default(active)
  rankId           String?   @map("rank_id") @db.Uuid
  availablePoints  Int       @default(0) @map("available_points")
  emailVerifiedAt  DateTime? @map("email_verified_at") @db.Timestamptz()
  isAdmin          Boolean   @default(false) @map("is_admin")
  isActive         Boolean   @default(true) @map("is_active")
  lastLoginAt      DateTime? @map("last_login_at") @db.Timestamptz()
  joinedAt         DateTime? @map("joined_at") @db.Timestamptz()
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz()

  // Relations
  rank                   MemberRank?         @relation(fields: [rankId], references: [id])
  socialAccounts         SocialAccount[]
  loginHistories         LoginHistory[]
  refreshTokens          RefreshToken[]
  passwordResetTokens    PasswordResetToken[]
  profile                UserProfile?
  interests              UserInterest[]
  languages              UserLanguage[]
  affiliations           UserAffiliation[]
  publicInfo             UserPublicInfo?
  files                  File[]
  updatedFeatureSettings FeatureSetting[]    @relation("FeatureUpdatedBy")
  updatedAppSettings     AppSetting[]        @relation("AppSettingUpdatedBy")
  // Phase 2
  notifications           Notification[]           @relation("NotificationRecipient")
  actedNotifications      Notification[]           @relation("NotificationActor")
  notificationPreferences NotificationPreference[]
  boardCategories         BoardCategory[]
  boardPosts              BoardPost[]
  boardComments           BoardComment[]
  boardLikes              BoardLike[]
  boardTopics             BoardTopic[]
  boardTopicPosts         BoardTopicPost[]
  boardTopicPostComments  BoardTopicPostComment[]
  // Phase 3
  createdChatRooms        ChatRoom[]               @relation("ChatRoomCreator")
  chatRoomMemberships     ChatRoomMember[]
  chatMessages            ChatMessage[]            @relation("ChatMessageSender")
  createdMailMessages     MailMessage[]             @relation("MailMessageCreator")
  mailRecipients          MailMessageRecipient[]    @relation("MailRecipient")
  // Phase 4
  attributeValues         MemberAttributeValue[]
  // Phase 5
  createdEvents           Event[]              @relation("EventCreator")
  eventParticipations     EventParticipant[]
  eventSpeakerProfiles    EventSpeaker[]
  eventBoardPosts         EventBoardPost[]
  eventBoardComments      EventBoardComment[]
  eventFiles              EventFile[]
  eventResults            EventResult[]
  // Phase 6
  createdProjects         Project[]                @relation("ProjectCreator")
  projectMemberships      ProjectMember[]
  projectThreads          ProjectThread[]
  projectThreadReplies    ProjectThreadReply[]
  projectThreadLikes      ProjectThreadLike[]
  projectFiles            ProjectFile[]
  projectTasks            ProjectTask[]
  projectTaskAssignees    ProjectTaskAssignee[]
  projectBoardPosts       ProjectBoardPost[]
  projectBoardComments    ProjectBoardComment[]
  projectBoardLikes       ProjectBoardLike[]

  @@index([role])
  @@index([status])
  @@map("users")
}

model SocialAccount {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String         @map("user_id") @db.Uuid
  provider       SocialProvider
  providerUserId String         @map("provider_user_id") @db.VarChar(255)
  accessToken    String?        @map("access_token") @db.Text
  refreshToken   String?        @map("refresh_token") @db.Text
  tokenExpiresAt DateTime?      @map("token_expires_at") @db.Timestamptz()
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("social_accounts")
}

model LoginHistory {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String      @map("user_id") @db.Uuid
  ipAddress     String      @map("ip_address") @db.Inet
  userAgent     String?     @map("user_agent") @db.Text
  status        LoginStatus
  failureReason String?     @map("failure_reason") @db.VarChar(50)
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("login_histories")
}

model RefreshToken {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash") @db.VarChar(255)
  deviceInfo String?   @map("device_info") @db.VarChar(255)
  ipAddress  String?   @map("ip_address") @db.Inet
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz()
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz()
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz()
  usedAt    DateTime? @map("used_at") @db.Timestamptz()
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model FeatureSetting {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  featureKey      String          @unique @map("feature_key") @db.VarChar(50)
  featureName     String          @map("feature_name") @db.VarChar(100)
  category        FeatureCategory
  isEnabled       Boolean         @default(true) @map("is_enabled")
  description     String?         @db.Text
  sortOrder       Int             @default(0) @map("sort_order")
  enabledAt       DateTime?       @map("enabled_at") @db.Timestamptz()
  disabledAt      DateTime?       @map("disabled_at") @db.Timestamptz()
  updatedByUserId String?         @map("updated_by_user_id") @db.Uuid
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  updatedByUser       User?               @relation("FeatureUpdatedBy", fields: [updatedByUserId], references: [id])
  permissionSettings  PermissionSetting[]

  @@index([category])
  @@index([isEnabled])
  @@map("feature_settings")
}

model MemberRank {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @db.VarChar(50)
  slug      String   @unique @db.VarChar(50)
  color     String?  @db.VarChar(7)
  sortOrder Int      @default(0) @map("sort_order")
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  users              User[]
  permissionSettings PermissionSetting[]
  categories         Category[]
  // Phase 2
  boardPosts BoardPost[]
  // Phase 5
  events Event[]

  @@index([sortOrder])
  @@map("member_ranks")
}

model PermissionSetting {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  featureKey     String  @map("feature_key") @db.VarChar(50)
  action         String  @db.VarChar(50)
  allowedRoles   Json    @default("[\"owner\",\"admin\"]") @map("allowed_roles") @db.JsonB
  requiredRankId String? @map("required_rank_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  featureSetting FeatureSetting @relation(fields: [featureKey], references: [featureKey], onDelete: Cascade)
  requiredRank   MemberRank?    @relation(fields: [requiredRankId], references: [id])

  @@unique([featureKey, action])
  @@index([featureKey])
  @@map("permission_settings")
}

model AppSetting {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key             String          @unique @db.VarChar(100)
  value           String          @db.Text
  valueType       SettingValueType @default(string) @map("value_type")
  description     String?         @db.Text
  updatedByUserId String?         @map("updated_by_user_id") @db.Uuid
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  updatedByUser User? @relation("AppSettingUpdatedBy", fields: [updatedByUserId], references: [id])

  @@map("app_settings")
}

model Category {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parentId          String?   @map("parent_id") @db.Uuid
  scope             String    @db.VarChar(30)
  name              String    @db.VarChar(100)
  slug              String    @db.VarChar(100)
  description       String?   @db.Text
  iconUrl           String?   @map("icon_url") @db.VarChar(500)
  sortOrder         Int       @default(0) @map("sort_order")
  allowPostCreation Boolean   @default(true) @map("allow_post_creation")
  requiredRankId    String?   @map("required_rank_id") @db.Uuid
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  parent        Category?      @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children      Category[]     @relation("CategoryHierarchy")
  requiredRank  MemberRank?    @relation(fields: [requiredRankId], references: [id])
  userInterests UserInterest[]
  // Phase 5
  events Event[]
  // Phase 6
  projects        Project[]
  projectBoardPosts ProjectBoardPost[]

  @@unique([scope, slug])
  @@index([scope, sortOrder])
  @@index([requiredRankId])
  @@map("categories")
}

model Tag {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String   @db.VarChar(50)
  slug       String   @unique @db.VarChar(50)
  usageCount Int      @default(0) @map("usage_count")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  // Phase 2
  boardPostTags BoardPostTag[]
  // Phase 5
  eventTags EventTag[]
  // Phase 6
  projectTags ProjectTag[]

  @@map("tags")
}

model File {
  id                  String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  uploadedByUserId    String       @map("uploaded_by_user_id") @db.Uuid
  originalName        String       @map("original_name") @db.VarChar(255)
  storageKey          String       @unique @map("storage_key") @db.VarChar(500)
  storageBucket       String       @map("storage_bucket") @db.VarChar(100)
  contentType         String       @map("content_type") @db.VarChar(100)
  fileSizeBytes       BigInt       @map("file_size_bytes")
  fileCategory        FileCategory @default(general) @map("file_category")
  imageWidth          Int?         @map("image_width")
  imageHeight         Int?         @map("image_height")
  thumbnailStorageKey String?      @map("thumbnail_storage_key") @db.VarChar(500)
  checksumSha256      String?      @map("checksum_sha256") @db.VarChar(64)
  isPublic            Boolean      @default(false) @map("is_public")
  publicUrl           String?      @map("public_url") @db.VarChar(500)
  createdAt           DateTime     @default(now()) @map("created_at") @db.Timestamptz()
  deletedAt           DateTime?    @map("deleted_at") @db.Timestamptz()

  // Relations
  uploadedByUser User @relation(fields: [uploadedByUserId], references: [id])
  // Phase 2
  boardPostAttachments BoardPostAttachment[]
  // Phase 3
  chatMessages             ChatMessage[]
  mailMessageAttachments   MailMessageAttachment[]
  // Phase 5
  eventFiles               EventFile[]
  eventResultAttachments   EventResultAttachment[]
  // Phase 6
  projectFiles                   ProjectFile[]
  projectThreadReplyAttachments  ProjectThreadReplyAttachment[]
  projectTaskAttachments         ProjectTaskAttachment[]
  projectBoardPostAttachments    ProjectBoardPostAttachment[]

  @@index([uploadedByUserId])
  @@index([storageKey])
  @@index([createdAt(sort: Desc)])
  @@map("files")
}

model UserProfile {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId              String    @unique @map("user_id") @db.Uuid
  avatarUrl           String?   @map("avatar_url") @db.VarChar(500)
  bio                 String?   @db.Text
  phone               String?   @db.VarChar(20)
  birthday            DateTime? @db.Date
  website             String?   @db.VarChar(500)
  memberCardBarcode   String?   @unique @map("member_card_barcode") @db.VarChar(100)
  nameKana            String?   @map("name_kana") @db.VarChar(100)
  gender              Gender?
  occupation          String?   @db.VarChar(100)
  countryOfOrigin     String?   @map("country_of_origin") @db.VarChar(100)
  allowDirectMessages Boolean   @default(true) @map("allow_direct_messages")
  headerImageUrl      String?   @map("header_image_url") @db.VarChar(500)
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model UserInterest {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  categoryId String   @map("category_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId])
  @@index([categoryId])
  @@map("user_interests")
}

model UserLanguage {
  id           String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String               @map("user_id") @db.Uuid
  languageCode String               @map("language_code") @db.VarChar(10)
  proficiency  LanguageProficiency?
  sortOrder    Int                  @default(0) @map("sort_order")
  createdAt    DateTime             @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, languageCode])
  @@map("user_languages")
}

model UserAffiliation {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  organizationName String   @map("organization_name") @db.VarChar(200)
  title            String?  @db.VarChar(100)
  roleDescription  String?  @map("role_description") @db.VarChar(200)
  sortOrder        Int      @default(0) @map("sort_order")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sortOrder])
  @@map("user_affiliations")
}

model UserPublicInfo {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String       @unique @map("user_id") @db.Uuid
  nickname       String?      @db.VarChar(100)
  nicknameKana   String?      @map("nickname_kana") @db.VarChar(100)
  specialty      String?      @db.VarChar(200)
  prefecture     String?      @db.VarChar(50)
  city           String?      @db.VarChar(100)
  foreignCountry String?     @map("foreign_country") @db.VarChar(100)
  foreignCity    String?      @map("foreign_city") @db.VarChar(100)
  introduction   String?      @db.Text
  eventRole      String?      @map("event_role") @db.VarChar(50)
  publicStatus   PublicStatus @default(private) @map("public_status")
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([publicStatus])
  @@map("user_public_info")
}

// ============================================================
// Phase 2: 掲示板・通知
// ============================================================

// --- Enums ---

enum BoardPublishStatus {
  draft
  published
  archived
}

enum BoardViewPermission {
  all
  rank_restricted
}

// --- Models ---

model Notification {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  type          String    @db.VarChar(30)
  title         String    @db.VarChar(200)
  body          String?   @db.Text
  referenceType String?   @map("reference_type") @db.VarChar(30)
  referenceId   String?   @map("reference_id") @db.Uuid
  actorUserId   String?   @map("actor_user_id") @db.Uuid
  isRead        Boolean   @default(false) @map("is_read")
  readAt        DateTime? @map("read_at") @db.Timestamptz()
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  user  User  @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor User? @relation("NotificationActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([userId, isRead, createdAt(sort: Desc)])
  @@map("notifications")
}

model NotificationPreference {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  notificationType String   @map("notification_type") @db.VarChar(30)
  emailEnabled     Boolean  @default(true) @map("email_enabled")
  inAppEnabled     Boolean  @default(true) @map("in_app_enabled")
  lineEnabled      Boolean  @default(false) @map("line_enabled")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, notificationType])
  @@map("notification_preferences")
}

model BoardCategory {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String    @db.VarChar(100)
  description     String?   @db.Text
  sortOrder            Int       @default(0) @map("sort_order")
  allowTopicCreation   Boolean   @default(true) @map("allow_topic_creation")
  createdByUserId      String    @map("created_by_user_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz()

  // Relations
  createdByUser User         @relation(fields: [createdByUserId], references: [id])
  posts         BoardPost[]
  topics        BoardTopic[]

  @@index([sortOrder])
  @@map("board_categories")
}

model BoardPost {
  id              String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId      String?             @map("category_id") @db.Uuid
  authorUserId    String              @map("author_user_id") @db.Uuid
  language        String?             @default("ja") @db.VarChar(20)
  title           String              @db.VarChar(200)
  body            String              @db.Text
  publishStatus   BoardPublishStatus  @default(draft) @map("publish_status")
  sortOrder       Int                 @default(0) @map("sort_order")
  isPinned        Boolean             @default(false) @map("is_pinned")
  viewCount       Int                 @default(0) @map("view_count")
  commentCount    Int                 @default(0) @map("comment_count")
  likeCount       Int                 @default(0) @map("like_count")
  reactionCount   Int                 @default(0) @map("reaction_count")
  viewPermission  BoardViewPermission @default(all) @map("view_permission")
  requiredRankId  String?             @map("required_rank_id") @db.Uuid
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime            @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt       DateTime?           @map("deleted_at") @db.Timestamptz()

  // Relations
  category     BoardCategory?        @relation(fields: [categoryId], references: [id])
  author       User                  @relation(fields: [authorUserId], references: [id])
  requiredRank MemberRank?           @relation(fields: [requiredRankId], references: [id])
  attachments  BoardPostAttachment[]
  tags         BoardPostTag[]
  comments     BoardComment[]

  @@index([publishStatus, isPinned(sort: Desc), sortOrder, createdAt(sort: Desc)])
  @@index([categoryId])
  @@index([authorUserId])
  @@map("board_posts")
}

model BoardPostAttachment {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  fileId    String   @map("file_id") @db.Uuid
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  post BoardPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  file File      @relation(fields: [fileId], references: [id])

  @@index([postId, sortOrder])
  @@map("board_post_attachments")
}

model BoardPostTag {
  postId String @map("post_id") @db.Uuid
  tagId  String @map("tag_id") @db.Uuid

  // Relations
  post BoardPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId])
  @@map("board_post_tags")
}

model BoardComment {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  postId          String    @map("post_id") @db.Uuid
  authorUserId    String    @map("author_user_id") @db.Uuid
  parentCommentId String?   @map("parent_comment_id") @db.Uuid
  body            String    @db.Text
  likeCount       Int       @default(0) @map("like_count")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz()

  // Relations
  post          BoardPost     @relation(fields: [postId], references: [id], onDelete: Cascade)
  author        User          @relation(fields: [authorUserId], references: [id])
  parentComment BoardComment? @relation("CommentHierarchy", fields: [parentCommentId], references: [id])
  childComments BoardComment[] @relation("CommentHierarchy")

  @@index([postId, createdAt])
  @@index([parentCommentId])
  @@index([authorUserId])
  @@map("board_comments")
}

model BoardLike {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  targetType String   @map("target_type") @db.VarChar(20)
  targetId   String   @map("target_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetType, targetId])
  @@index([targetType, targetId])
  @@map("board_likes")
}

model BoardTopic {
  id              String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId      String              @map("category_id") @db.Uuid
  authorUserId    String              @map("author_user_id") @db.Uuid
  title           String              @db.VarChar(200)
  body            String              @db.Text
  publishStatus   BoardPublishStatus  @default(published) @map("publish_status")
  isPinned        Boolean             @default(false) @map("is_pinned")
  sortOrder       Int                 @default(0) @map("sort_order")
  viewCount       Int                 @default(0) @map("view_count")
  postCount       Int                 @default(0) @map("post_count")
  likeCount       Int                 @default(0) @map("like_count")
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime            @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt       DateTime?           @map("deleted_at") @db.Timestamptz()

  // Relations
  category BoardCategory       @relation(fields: [categoryId], references: [id])
  author   User                @relation(fields: [authorUserId], references: [id])
  posts    BoardTopicPost[]

  @@index([categoryId, isPinned(sort: Desc), sortOrder, createdAt(sort: Desc)])
  @@index([authorUserId])
  @@map("board_topics")
}

model BoardTopicPost {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  topicId         String    @map("topic_id") @db.Uuid
  authorUserId    String    @map("author_user_id") @db.Uuid
  body            String    @db.Text
  likeCount       Int       @default(0) @map("like_count")
  commentCount    Int       @default(0) @map("comment_count")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz()

  // Relations
  topic    BoardTopic             @relation(fields: [topicId], references: [id], onDelete: Cascade)
  author   User                   @relation(fields: [authorUserId], references: [id])
  comments BoardTopicPostComment[]

  @@index([topicId, createdAt])
  @@index([authorUserId])
  @@map("board_topic_posts")
}

model BoardTopicPostComment {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  postId          String    @map("post_id") @db.Uuid
  authorUserId    String    @map("author_user_id") @db.Uuid
  parentCommentId String?   @map("parent_comment_id") @db.Uuid
  body            String    @db.Text
  likeCount       Int       @default(0) @map("like_count")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz()

  // Relations
  post          BoardTopicPost         @relation(fields: [postId], references: [id], onDelete: Cascade)
  author        User                   @relation(fields: [authorUserId], references: [id])
  parentComment BoardTopicPostComment? @relation("TopicPostCommentHierarchy", fields: [parentCommentId], references: [id])
  childComments BoardTopicPostComment[] @relation("TopicPostCommentHierarchy")

  @@index([postId, createdAt])
  @@index([parentCommentId])
  @@index([authorUserId])
  @@map("board_topic_post_comments")
}

// ============================================================
// Phase 3: チャット・メール配信
// ============================================================

// --- Enums ---

enum ChatRoomType {
  dm
  group
}

enum ChatRoomMemberRole {
  admin
  member
}

enum ChatMessageType {
  text
  image
  file
}

enum MailTargetType {
  all
  rank
  custom
  event
}

enum MailStatus {
  draft
  scheduled
  sending
  sent
  failed
}

enum MailRecipientStatus {
  pending
  sent
  delivered
  bounced
  opened
  clicked
  failed
}

enum MailSuppressionReason {
  unsubscribe
  bounce
  complaint
  manual
}

enum MailTemplateCategory {
  event
  general
}

// --- Models ---

model ChatRoom {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type            ChatRoomType @default(dm)
  name            String?      @db.VarChar(100)
  description     String?      @db.Text
  iconUrl         String?      @map("icon_url") @db.VarChar(500)
  createdByUserId String?      @map("created_by_user_id") @db.Uuid
  maxMembers      Int?         @map("max_members")
  lastMessageAt   DateTime?    @map("last_message_at") @db.Timestamptz()
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  createdByUser User?            @relation("ChatRoomCreator", fields: [createdByUserId], references: [id])
  members       ChatRoomMember[]
  messages      ChatMessage[]

  @@index([lastMessageAt(sort: Desc)])
  @@index([type])
  @@map("chat_rooms")
}

model ChatRoomMember {
  id         String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chatRoomId String             @map("chat_room_id") @db.Uuid
  userId     String             @map("user_id") @db.Uuid
  role       ChatRoomMemberRole @default(member)
  lastReadAt DateTime?          @map("last_read_at") @db.Timestamptz()
  isMuted    Boolean            @default(false) @map("is_muted")
  joinedAt   DateTime           @default(now()) @map("joined_at") @db.Timestamptz()
  createdAt  DateTime           @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  chatRoom ChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatRoomId, userId])
  @@index([userId])
  @@map("chat_room_members")
}

model ChatMessage {
  id           String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chatRoomId   String          @map("chat_room_id") @db.Uuid
  senderUserId String          @map("sender_user_id") @db.Uuid
  messageType  ChatMessageType @default(text) @map("message_type")
  body         String?         @db.Text
  fileId       String?         @map("file_id") @db.Uuid
  createdAt    DateTime        @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime        @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt    DateTime?       @map("deleted_at") @db.Timestamptz()

  // Relations
  chatRoom ChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  sender   User     @relation("ChatMessageSender", fields: [senderUserId], references: [id])
  file     File?    @relation(fields: [fileId], references: [id])

  @@index([chatRoomId, createdAt(sort: Desc)])
  @@index([senderUserId])
  @@map("chat_messages")
}

model MailMessage {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subject         String         @db.VarChar(200)
  bodyHtml        String         @map("body_html") @db.Text
  bodyText        String?        @map("body_text") @db.Text
  targetType      MailTargetType @map("target_type")
  targetFilter    Json?          @map("target_filter") @db.JsonB
  templateId      String?        @map("template_id") @db.Uuid
  status          MailStatus     @default(draft)
  scheduledAt     DateTime?      @map("scheduled_at") @db.Timestamptz()
  sentAt          DateTime?      @map("sent_at") @db.Timestamptz()
  totalRecipients Int            @default(0) @map("total_recipients")
  sentCount       Int            @default(0) @map("sent_count")
  deliveredCount  Int            @default(0) @map("delivered_count")
  failedCount     Int            @default(0) @map("failed_count")
  lineSentCount   Int            @default(0) @map("line_sent_count")
  createdByUserId String         @map("created_by_user_id") @db.Uuid
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  createdByUser User                   @relation("MailMessageCreator", fields: [createdByUserId], references: [id])
  template      MailTemplate?          @relation(fields: [templateId], references: [id])
  recipients    MailMessageRecipient[]
  attachments   MailMessageAttachment[]

  @@index([status, createdAt(sort: Desc)])
  @@map("mail_messages")
}

model MailMessageRecipient {
  id        String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  messageId String              @map("message_id") @db.Uuid
  userId    String              @map("user_id") @db.Uuid
  email     String              @db.VarChar(255)
  status    MailRecipientStatus @default(pending)
  sentAt    DateTime?           @map("sent_at") @db.Timestamptz()
  openedAt  DateTime?           @map("opened_at") @db.Timestamptz()
  clickedAt DateTime?           @map("clicked_at") @db.Timestamptz()
  createdAt DateTime            @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  message MailMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User        @relation("MailRecipient", fields: [userId], references: [id])

  @@unique([messageId, userId])
  @@index([messageId, status])
  @@map("mail_message_recipients")
}

model MailMessageAttachment {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  messageId String   @map("message_id") @db.Uuid
  fileId    String   @map("file_id") @db.Uuid
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  message MailMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  file    File        @relation(fields: [fileId], references: [id])

  @@index([messageId, sortOrder])
  @@map("mail_message_attachments")
}

model MailSuppression {
  id        String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String                @unique @db.VarChar(255)
  reason    MailSuppressionReason
  createdAt DateTime              @default(now()) @map("created_at") @db.Timestamptz()

  @@map("mail_suppressions")
}

model MailTemplate {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String               @db.VarChar(100)
  category           MailTemplateCategory
  subjectTemplate    String               @map("subject_template") @db.VarChar(200)
  bodyHtmlTemplate   String               @map("body_html_template") @db.Text
  bodyTextTemplate   String?              @map("body_text_template") @db.Text
  availableVariables Json?                @map("available_variables") @db.JsonB
  sortOrder          Int                  @default(0) @map("sort_order")
  createdAt          DateTime             @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt          DateTime             @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  mailMessages MailMessage[]

  @@index([category, sortOrder])
  @@map("mail_templates")
}

// ============================================================
// Phase 4: メンバー管理完成
// ============================================================

// --- Enums ---

enum AttributeType {
  text
  number
  date
  select
  multi_select
}

// --- Models ---

model MemberAttribute {
  id         String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String        @db.VarChar(100)
  slug       String        @unique @db.VarChar(100)
  type       AttributeType
  options    Json?         @db.JsonB
  isRequired Boolean       @default(false) @map("is_required")
  sortOrder  Int           @default(0) @map("sort_order")
  createdAt  DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt  DateTime      @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  values MemberAttributeValue[]

  @@index([sortOrder])
  @@map("member_attributes")
}

model MemberAttributeValue {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  attributeId String   @map("attribute_id") @db.Uuid
  value       String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  attribute MemberAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@unique([userId, attributeId])
  @@index([attributeId])
  @@map("member_attribute_values")
}

// ============================================================
// Phase 5: イベント
// ============================================================

// --- Enums ---

enum EventLocationType {
  venue
  online
  hybrid
}

enum EventStatus {
  draft
  recruiting
  closed
  canceled
  ended
}

enum ParticipantStatus {
  applied
  confirmed
  canceled
  attended
  no_show
}

enum PaymentStatus {
  pending
  paid
  canceled
}

enum EventResultStatus {
  draft
  completed
}

// --- Models ---

model Event {
  id                       String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title                    String           @db.VarChar(200)
  description              String?          @db.Text
  locationType             EventLocationType @default(venue) @map("location_type")
  venueName                String?          @map("venue_name") @db.VarChar(300)
  venueAddress             String?          @map("venue_address") @db.VarChar(500)
  onlineUrl                String?          @map("online_url") @db.VarChar(500)
  startAt                  DateTime         @map("start_at") @db.Timestamptz()
  endAt                    DateTime         @map("end_at") @db.Timestamptz()
  registrationDeadlineAt   DateTime?        @map("registration_deadline_at") @db.Timestamptz()
  ticketSaleStartAt        DateTime?        @map("ticket_sale_start_at") @db.Timestamptz()
  allowMultiTicketPurchase Boolean          @default(false) @map("allow_multi_ticket_purchase")
  acceptedPaymentMethods   Json?            @map("accepted_payment_methods") @db.JsonB
  planningRole             String           @default("主催") @map("planning_role") @db.VarChar(30)
  eventType                String?          @map("event_type") @db.VarChar(30)
  categoryId               String?          @map("category_id") @db.Uuid
  accessInfo               String?          @map("access_info") @db.Text
  participationMethod      String?          @map("participation_method") @db.Text
  contactInfo              String?          @map("contact_info") @db.Text
  cancellationPolicy       String?          @map("cancellation_policy") @db.Text
  language                 String?          @default("ja") @db.VarChar(20)
  isAttendeeVisible        Boolean          @default(false) @map("is_attendee_visible")
  status                   EventStatus      @default(draft)
  coverImageUrl            String?          @map("cover_image_url") @db.VarChar(500)
  createdByUserId          String           @map("created_by_user_id") @db.Uuid
  requiredRankId           String?          @map("required_rank_id") @db.Uuid
  participantCount         Int              @default(0) @map("participant_count")
  isCalendarVisible        Boolean          @default(true) @map("is_calendar_visible")
  createdAt                DateTime         @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt                DateTime         @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt                DateTime?        @map("deleted_at") @db.Timestamptz()

  // Relations
  createdByUser  User                @relation("EventCreator", fields: [createdByUserId], references: [id])
  category       Category?           @relation(fields: [categoryId], references: [id])
  requiredRank   MemberRank?         @relation(fields: [requiredRankId], references: [id])
  tickets        EventTicket[]
  participants   EventParticipant[]
  speakers       EventSpeaker[]
  organizations  EventOrganization[]
  tags           EventTag[]
  boardPosts     EventBoardPost[]
  files          EventFile[]
  result         EventResult?
  // Phase 6
  projects       Project[]

  @@index([status, startAt])
  @@index([startAt])
  @@index([createdByUserId])
  @@index([categoryId])
  @@map("events")
}

model EventTicket {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId       String   @map("event_id") @db.Uuid
  ticketName    String   @map("ticket_name") @db.VarChar(100)
  price         Int      @default(0)
  currency      String   @default("JPY") @db.VarChar(3)
  capacity      Int?
  purchaseLimit Int      @default(1) @map("purchase_limit")
  sortOrder     Int      @default(0) @map("sort_order")
  isActive      Boolean  @default(true) @map("is_active")
  soldCount     Int      @default(0) @map("sold_count")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  event         Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  participants  EventParticipant[]
  discountCodes EventDiscountCode[]

  @@index([eventId, sortOrder])
  @@map("event_tickets")
}

model EventParticipant {
  id             String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId        String             @map("event_id") @db.Uuid
  userId         String             @map("user_id") @db.Uuid
  ticketId       String?            @map("ticket_id") @db.Uuid
  quantity       Int                @default(1)
  status         ParticipantStatus  @default(applied)
  paymentStatus  PaymentStatus?     @map("payment_status")
  paymentMethod  String?            @map("payment_method") @db.VarChar(30)
  discountCodeId String?            @map("discount_code_id") @db.Uuid
  appliedAt      DateTime           @default(now()) @map("applied_at") @db.Timestamptz()
  canceledAt     DateTime?          @map("canceled_at") @db.Timestamptz()
  createdAt      DateTime           @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime           @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  event        Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user         User               @relation(fields: [userId], references: [id])
  ticket       EventTicket?       @relation(fields: [ticketId], references: [id])
  discountCode EventDiscountCode? @relation(fields: [discountCodeId], references: [id])

  @@unique([eventId, userId, ticketId])
  @@index([userId])
  @@index([eventId, status])
  @@map("event_participants")
}

model EventSpeaker {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId   String   @map("event_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  name      String   @db.VarChar(100)
  title     String?  @db.VarChar(100)
  role      String   @db.VarChar(30)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id])

  @@index([eventId, sortOrder])
  @@map("event_speakers")
}

model EventOrganization {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId          String   @map("event_id") @db.Uuid
  organizationName String   @map("organization_name") @db.VarChar(200)
  role             String   @db.VarChar(30)
  sortOrder        Int      @default(0) @map("sort_order")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, sortOrder])
  @@map("event_organizations")
}

model EventTag {
  eventId String @map("event_id") @db.Uuid
  tagId   String @map("tag_id") @db.Uuid

  // Relations
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([eventId, tagId])
  @@index([tagId])
  @@map("event_tags")
}

model EventBoardPost {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId      String    @map("event_id") @db.Uuid
  authorUserId String    @map("author_user_id") @db.Uuid
  body         String    @db.Text
  likeCount    Int       @default(0) @map("like_count")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz()

  // Relations
  event    Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  author   User               @relation(fields: [authorUserId], references: [id])
  comments EventBoardComment[]

  @@index([eventId, createdAt(sort: Desc)])
  @@map("event_board_posts")
}

model EventBoardComment {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  postId       String    @map("post_id") @db.Uuid
  authorUserId String    @map("author_user_id") @db.Uuid
  body         String    @db.Text
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz()

  // Relations
  post   EventBoardPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User           @relation(fields: [authorUserId], references: [id])

  @@index([postId, createdAt])
  @@map("event_board_comments")
}

model EventFile {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId          String    @map("event_id") @db.Uuid
  type             String    @default("file") @db.VarChar(10)
  name             String?   @db.VarChar(200)
  parentFolderId   String?   @map("parent_folder_id") @db.Uuid
  fileId           String?   @map("file_id") @db.Uuid
  sortOrder        Int       @default(0) @map("sort_order")
  uploadedByUserId String    @map("uploaded_by_user_id") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  event        Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  parentFolder EventFile? @relation("EventFileHierarchy", fields: [parentFolderId], references: [id])
  children     EventFile[] @relation("EventFileHierarchy")
  file         File?      @relation(fields: [fileId], references: [id])
  uploadedBy   User       @relation(fields: [uploadedByUserId], references: [id])

  @@index([eventId, parentFolderId, sortOrder])
  @@map("event_files")
}

model EventResult {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId          String            @unique @map("event_id") @db.Uuid
  attendanceCount  Int               @default(0) @map("attendance_count")
  attendanceRate   Decimal?          @map("attendance_rate") @db.Decimal(5, 2)
  achievementNotes String?           @map("achievement_notes") @db.Text
  summary          String?           @db.Text
  improvementNotes String?           @map("improvement_notes") @db.Text
  status           EventResultStatus @default(draft)
  publishStatus    PublicStatus      @default(private) @map("publish_status")
  createdByUserId  String            @map("created_by_user_id") @db.Uuid
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime          @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  event       Event                   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdBy   User                    @relation(fields: [createdByUserId], references: [id])
  attachments EventResultAttachment[]

  @@index([publishStatus])
  @@map("event_results")
}

model EventResultAttachment {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventResultId String   @map("event_result_id") @db.Uuid
  fileId        String   @map("file_id") @db.Uuid
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  eventResult EventResult @relation(fields: [eventResultId], references: [id], onDelete: Cascade)
  file        File        @relation(fields: [fileId], references: [id])

  @@index([eventResultId, sortOrder])
  @@map("event_result_attachments")
}

model EventDiscountCode {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticketId        String    @map("ticket_id") @db.Uuid
  code            String    @db.VarChar(50)
  discountedPrice Int       @map("discounted_price")
  usageLimit      Int?      @map("usage_limit")
  usedCount       Int       @default(0) @map("used_count")
  isActive        Boolean   @default(true) @map("is_active")
  expiresAt       DateTime? @map("expires_at") @db.Timestamptz()
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  ticket       EventTicket        @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  participants EventParticipant[]

  @@unique([ticketId, code])
  @@index([code])
  @@map("event_discount_codes")
}

// ============================================================
// Phase 6: プロジェクト管理
// ============================================================

// --- Enums ---

enum ProjectStatus {
  not_started
  in_progress
  completed
  cancelled
}

enum ProjectPublishStatus {
  draft
  published
  archived
}

enum ProjectMemberRole {
  admin
  member
}

enum ProjectMemberStatus {
  active
  withdrawn
  removed
}

enum ProjectBoardPublishStatus {
  draft
  published
  archived
}

// --- Models ---

model Project {
  id                String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String               @db.VarChar(200)
  description       String?              @db.Text
  coverImageUrl     String?              @map("cover_image_url") @db.VarChar(500)
  categoryId        String?              @map("category_id") @db.Uuid
  eventId           String?              @map("event_id") @db.Uuid
  startDate         DateTime?            @map("start_date") @db.Date
  endDate           DateTime?            @map("end_date") @db.Date
  status            ProjectStatus        @default(not_started)
  publishStatus     ProjectPublishStatus @default(draft) @map("publish_status")
  inviteToken       String               @unique @map("invite_token") @db.VarChar(100)
  inviteLinkEnabled Boolean              @default(false) @map("invite_link_enabled")
  memberCount       Int                  @default(0) @map("member_count")
  activityCount     Int                  @default(0) @map("activity_count")
  createdByUserId   String               @map("created_by_user_id") @db.Uuid
  createdAt         DateTime             @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime             @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt         DateTime?            @map("deleted_at") @db.Timestamptz()

  // Relations
  createdByUser User                @relation("ProjectCreator", fields: [createdByUserId], references: [id])
  category      Category?           @relation(fields: [categoryId], references: [id])
  event         Event?              @relation(fields: [eventId], references: [id])
  members       ProjectMember[]
  threads       ProjectThread[]
  tags          ProjectTag[]
  files         ProjectFile[]
  tasks         ProjectTask[]
  boardPosts    ProjectBoardPost[]

  @@index([publishStatus, status])
  @@index([createdByUserId])
  @@index([eventId])
  @@index([categoryId])
  @@map("projects")
}

model ProjectMember {
  id            String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId     String              @map("project_id") @db.Uuid
  userId        String              @map("user_id") @db.Uuid
  role          ProjectMemberRole   @default(member)
  status        ProjectMemberStatus @default(active)
  joinedAt      DateTime            @default(now()) @map("joined_at") @db.Timestamptz()
  removedAt     DateTime?           @map("removed_at") @db.Timestamptz()
  removedReason String?             @map("removed_reason") @db.Text
  createdAt     DateTime            @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime            @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
  @@index([userId])
  @@map("project_members")
}

model ProjectThread {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId       String    @map("project_id") @db.Uuid
  title           String    @db.VarChar(200)
  createdByUserId String    @map("created_by_user_id") @db.Uuid
  isPinned        Boolean   @default(false) @map("is_pinned")
  replyCount      Int       @default(0) @map("reply_count")
  likeCount       Int       @default(0) @map("like_count")
  lastReplyAt     DateTime? @map("last_reply_at") @db.Timestamptz()
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz()

  // Relations
  project   Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User                 @relation(fields: [createdByUserId], references: [id])
  replies   ProjectThreadReply[]
  likes     ProjectThreadLike[]  @relation("ThreadLikes")

  @@index([projectId, isPinned(sort: Desc), lastReplyAt(sort: Desc)])
  @@map("project_threads")
}

model ProjectThreadReply {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  threadId     String    @map("thread_id") @db.Uuid
  authorUserId String    @map("author_user_id") @db.Uuid
  body         String    @db.Text
  likeCount    Int       @default(0) @map("like_count")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz()

  // Relations
  thread      ProjectThread                  @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author      User                           @relation(fields: [authorUserId], references: [id])
  attachments ProjectThreadReplyAttachment[]
  likes       ProjectThreadLike[]            @relation("ReplyLikes")

  @@index([threadId, createdAt])
  @@map("project_thread_replies")
}

model ProjectThreadReplyAttachment {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  replyId   String   @map("reply_id") @db.Uuid
  fileId    String   @map("file_id") @db.Uuid
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  reply ProjectThreadReply @relation(fields: [replyId], references: [id], onDelete: Cascade)
  file  File               @relation(fields: [fileId], references: [id])

  @@index([replyId, sortOrder])
  @@map("project_thread_reply_attachments")
}

model ProjectThreadLike {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  threadId  String?  @map("thread_id") @db.Uuid
  replyId   String?  @map("reply_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  user   User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  thread ProjectThread?      @relation("ThreadLikes", fields: [threadId], references: [id], onDelete: Cascade)
  reply  ProjectThreadReply? @relation("ReplyLikes", fields: [replyId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@index([replyId])
  @@map("project_thread_likes")
}

model ProjectTag {
  projectId String   @map("project_id") @db.Uuid
  tagId     String   @map("tag_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([projectId, tagId])
  @@index([tagId])
  @@map("project_tags")
}

model ProjectFile {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId        String   @map("project_id") @db.Uuid
  type             String   @default("file") @db.VarChar(10)
  name             String?  @db.VarChar(200)
  parentFolderId   String?  @map("parent_folder_id") @db.Uuid
  fileId           String?  @map("file_id") @db.Uuid
  sortOrder        Int      @default(0) @map("sort_order")
  uploadedByUserId String   @map("uploaded_by_user_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentFolder ProjectFile? @relation("ProjectFileHierarchy", fields: [parentFolderId], references: [id])
  children     ProjectFile[] @relation("ProjectFileHierarchy")
  file         File?        @relation(fields: [fileId], references: [id])
  uploadedBy   User         @relation(fields: [uploadedByUserId], references: [id])

  @@index([projectId, parentFolderId, sortOrder])
  @@map("project_files")
}

model ProjectTask {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId       String    @map("project_id") @db.Uuid
  title           String    @db.VarChar(200)
  description     String?   @db.Text
  progress        Int       @default(0)
  requestedDate   DateTime? @map("requested_date") @db.Date
  dueDate         DateTime? @map("due_date") @db.Date
  notifyAssignee  Boolean   @default(false) @map("notify_assignee")
  sortOrder       Int       @default(0) @map("sort_order")
  createdByUserId String    @map("created_by_user_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  project     Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy   User                    @relation(fields: [createdByUserId], references: [id])
  assignees   ProjectTaskAssignee[]
  attachments ProjectTaskAttachment[]

  @@index([projectId, sortOrder])
  @@map("project_tasks")
}

model ProjectTaskAssignee {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  taskId    String   @map("task_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  task ProjectTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User        @relation(fields: [userId], references: [id])

  @@unique([taskId, userId])
  @@index([userId])
  @@map("project_task_assignees")
}

model ProjectTaskAttachment {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  taskId    String   @map("task_id") @db.Uuid
  fileId    String   @map("file_id") @db.Uuid
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  task ProjectTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  file File        @relation(fields: [fileId], references: [id])

  @@index([taskId, sortOrder])
  @@map("project_task_attachments")
}

model ProjectBoardPost {
  id            String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId     String                   @map("project_id") @db.Uuid
  categoryId    String?                  @map("category_id") @db.Uuid
  authorUserId  String                   @map("author_user_id") @db.Uuid
  language      String?                  @default("ja") @db.VarChar(20)
  title         String                   @db.VarChar(200)
  body          String                   @db.Text
  publishStatus ProjectBoardPublishStatus @default(draft) @map("publish_status")
  sortOrder     Int                      @default(0) @map("sort_order")
  isPinned      Boolean                  @default(false) @map("is_pinned")
  viewCount     Int                      @default(0) @map("view_count")
  commentCount  Int                      @default(0) @map("comment_count")
  likeCount     Int                      @default(0) @map("like_count")
  createdAt     DateTime                 @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime                 @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt     DateTime?                @map("deleted_at") @db.Timestamptz()

  // Relations
  project     Project                      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  category    Category?                    @relation(fields: [categoryId], references: [id])
  author      User                         @relation(fields: [authorUserId], references: [id])
  attachments ProjectBoardPostAttachment[]
  comments    ProjectBoardComment[]

  @@index([projectId, publishStatus, isPinned(sort: Desc), sortOrder, createdAt(sort: Desc)])
  @@index([authorUserId])
  @@map("project_board_posts")
}

model ProjectBoardPostAttachment {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  fileId    String   @map("file_id") @db.Uuid
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  post ProjectBoardPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  file File             @relation(fields: [fileId], references: [id])

  @@index([postId, sortOrder])
  @@map("project_board_post_attachments")
}

model ProjectBoardComment {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  postId          String    @map("post_id") @db.Uuid
  authorUserId    String    @map("author_user_id") @db.Uuid
  parentCommentId String?   @map("parent_comment_id") @db.Uuid
  body            String    @db.Text
  likeCount       Int       @default(0) @map("like_count")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz()

  // Relations
  post          ProjectBoardPost     @relation(fields: [postId], references: [id], onDelete: Cascade)
  author        User                 @relation(fields: [authorUserId], references: [id])
  parentComment ProjectBoardComment? @relation("ProjectCommentHierarchy", fields: [parentCommentId], references: [id])
  childComments ProjectBoardComment[] @relation("ProjectCommentHierarchy")

  @@index([postId, createdAt])
  @@index([parentCommentId])
  @@index([authorUserId])
  @@map("project_board_comments")
}

model ProjectBoardLike {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  targetType String   @map("target_type") @db.VarChar(30)
  targetId   String   @map("target_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetType, targetId])
  @@index([targetType, targetId])
  @@map("project_board_likes")
}
