// ============================================================================
// Community Platform - Prisma Schema
// PostgreSQL / 70 Models / 20 Modules
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// Module 1: ユーザー・認証
// ============================================================================

model User {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email           String    @unique @db.VarChar(255)
  passwordHash    String    @map("password_hash") @db.VarChar(255)
  name            String    @db.VarChar(100)
  displayName     String?   @map("display_name") @db.VarChar(100)
  avatarUrl       String?   @map("avatar_url") @db.VarChar(500)
  bio             String?
  phone           String?   @db.VarChar(20)
  role            String    @default("member") @db.VarChar(20) // owner/admin/moderator/member
  status          String    @default("active") @db.VarChar(20) // active/suspended/withdrawn
  rankId          String?   @map("rank_id") @db.Uuid
  pointBalance    Int       @default(0) @map("point_balance")
  emailVerifiedAt DateTime? @map("email_verified_at") @db.Timestamptz
  isAdmin         Boolean   @default(false) @map("is_admin")
  isActive        Boolean   @default(true) @map("is_active")
  lastLoginAt     DateTime? @map("last_login_at") @db.Timestamptz
  joinedAt        DateTime? @map("joined_at") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz

  // Relations
  rank                       MemberRank?            @relation(fields: [rankId], references: [id])
  socialAccounts             SocialAccount[]
  loginHistories             LoginHistory[]
  refreshTokens              RefreshToken[]
  passwordResetTokens        PasswordResetToken[]
  notifications              Notification[]         @relation("NotificationRecipient")
  actedNotifications         Notification[]         @relation("NotificationActor")
  events                     Event[]
  eventParticipants          EventParticipant[]
  boardPosts                 BoardPost[]
  boardComments              BoardComment[]
  boardLikes                 BoardLike[]
  videos                     Video[]
  videoWatchProgress         VideoWatchProgress[]
  videoTaskCompletions       VideoTaskCompletion[]
  chatRoomMembers            ChatRoomMember[]
  chatMessages               ChatMessage[]
  mailCampaigns              MailCampaign[]
  projects                   Project[]
  projectMembers             ProjectMember[]
  projectThreads             ProjectThread[]
  projectThreadReplies       ProjectThreadReply[]
  products                   Product[]
  orders                     Order[]
  payments                   Payment[]
  pointBalances              PointBalance[]
  pointTransactions          PointTransaction[]
  pointTransactionsGranted   PointTransaction[]     @relation("PointGranter")
  skillListings              SkillListing[]
  skillBookingsRequester     SkillBooking[]         @relation("BookingRequester")
  skillBookingsProvider      SkillBooking[]         @relation("BookingProvider")
  skillReviews               SkillReview[]
  skillMessages              SkillMessage[]
  surveys                    Survey[]
  surveyResponses            SurveyResponse[]
  lineUserConnections        LineUserConnection[]
  orientationCompletions     OrientationCompletion[]
  activityLogs               ActivityLog[]
  engagementScores           EngagementScore[]
  contentReports             ContentReport[]
  moderationActions          ModerationAction[]
  announcements              Announcement[]
  files                      File[]
  pushDeviceTokens           PushDeviceToken[]
  notificationPreferences    NotificationPreference[]
  auditLogs                  AuditLog[]

  @@index([role])
  @@index([status])
  @@index([rankId])
  @@map("users")
}

model SocialAccount {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  provider       String    @db.VarChar(20)
  providerUserId String    @map("provider_user_id") @db.VarChar(255)
  accessToken    String?   @map("access_token")
  refreshToken   String?   @map("refresh_token")
  tokenExpiresAt DateTime? @map("token_expires_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("social_accounts")
}

model LoginHistory {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  ipAddress     String   @map("ip_address") @db.Inet
  userAgent     String?  @map("user_agent")
  status        String   @db.VarChar(10)
  failureReason String?  @map("failure_reason") @db.VarChar(50)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt(sort: Desc)])
  @@map("login_histories")
}

model RefreshToken {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash") @db.VarChar(255)
  deviceInfo String?   @map("device_info") @db.VarChar(255)
  ipAddress  String?   @map("ip_address") @db.Inet
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  usedAt    DateTime? @map("used_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@map("password_reset_tokens")
}

// ============================================================================
// Module 2: コミュニティ管理
// ============================================================================

model MemberRank {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @db.VarChar(50)
  slug      String   @unique @db.VarChar(50)
  color     String?  @db.VarChar(7)
  sortOrder Int      @default(0) @map("sort_order")
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  users                User[]
  events               Event[]               @relation("EventRequiredRank")
  boardPosts           BoardPost[]           @relation("BoardPostRequiredRank")
  videos               Video[]               @relation("VideoRequiredRank")
  permissionSettings   PermissionSetting[]

  @@index([sortOrder])
  @@map("member_ranks")
}

model PermissionSetting {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  feature        String   @unique @db.VarChar(50)
  allowedRoles   Json     @default("[\"owner\",\"admin\"]") @map("allowed_roles") @db.JsonB
  requiredRankId String?  @map("required_rank_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  requiredRank MemberRank? @relation(fields: [requiredRankId], references: [id])

  @@map("permission_settings")
}

model AppSetting {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key             String   @unique @db.VarChar(100)
  value           String   @db.Text
  valueType       String   @default("string") @map("value_type") @db.VarChar(10)
  description     String?
  updatedByUserId String?  @map("updated_by_user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("app_settings")
}

// ============================================================================
// Module 3: 通知
// ============================================================================

model Notification {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  type          String    @db.VarChar(30)
  title         String    @db.VarChar(200)
  body          String?
  referenceType String?   @map("reference_type") @db.VarChar(30)
  referenceId   String?   @map("reference_id") @db.Uuid
  actorUserId   String?   @map("actor_user_id") @db.Uuid
  isRead        Boolean   @default(false) @map("is_read")
  readAt        DateTime? @map("read_at") @db.Timestamptz
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user  User  @relation("NotificationRecipient", fields: [userId], references: [id])
  actor User? @relation("NotificationActor", fields: [actorUserId], references: [id])

  @@index([userId, isRead, createdAt(sort: Desc)])
  @@map("notifications")
}

model NotificationPreference {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  notificationType String   @map("notification_type") @db.VarChar(30)
  emailEnabled     Boolean  @default(true) @map("email_enabled")
  pushEnabled      Boolean  @default(true) @map("push_enabled")
  inAppEnabled     Boolean  @default(true) @map("in_app_enabled")
  lineEnabled      Boolean  @default(false) @map("line_enabled")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, notificationType])
  @@map("notification_preferences")
}

model PushDeviceToken {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  platform    String    @db.VarChar(10)
  deviceToken String    @map("device_token") @db.VarChar(500)
  isActive    Boolean   @default(true) @map("is_active")
  lastUsedAt  DateTime? @map("last_used_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, deviceToken])
  @@map("push_device_tokens")
}

// ============================================================================
// Module 4: イベント
// ============================================================================

model Event {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title             String    @db.VarChar(200)
  description       String?
  location          String?   @db.VarChar(300)
  locationUrl       String?   @map("location_url") @db.VarChar(500)
  startAt           DateTime  @map("start_at") @db.Timestamptz
  endAt             DateTime  @map("end_at") @db.Timestamptz
  capacity          Int?
  fee               Int       @default(0)
  feeType           String    @default("free") @map("fee_type") @db.VarChar(10)
  status            String    @default("draft") @db.VarChar(20)
  coverImageUrl     String?   @map("cover_image_url") @db.VarChar(500)
  createdByUserId   String    @map("created_by_user_id") @db.Uuid
  requiredRankId    String?   @map("required_rank_id") @db.Uuid
  participantCount  Int       @default(0) @map("participant_count")
  isCalendarVisible Boolean   @default(true) @map("is_calendar_visible")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt         DateTime? @map("deleted_at") @db.Timestamptz

  createdBy    User               @relation(fields: [createdByUserId], references: [id])
  requiredRank MemberRank?        @relation("EventRequiredRank", fields: [requiredRankId], references: [id])
  participants EventParticipant[]
  payments     Payment[]

  @@index([status, startAt])
  @@index([startAt])
  @@index([createdByUserId])
  @@map("events")
}

model EventParticipant {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId       String    @map("event_id") @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  status        String    @default("applied") @db.VarChar(20)
  paymentStatus String?   @map("payment_status") @db.VarChar(20)
  paymentId     String?   @map("payment_id") @db.Uuid
  appliedAt     DateTime  @default(now()) @map("applied_at") @db.Timestamptz
  canceledAt    DateTime? @map("canceled_at") @db.Timestamptz
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  event   Event    @relation(fields: [eventId], references: [id])
  user    User     @relation(fields: [userId], references: [id])
  payment Payment? @relation(fields: [paymentId], references: [id])

  @@unique([eventId, userId])
  @@index([userId])
  @@index([eventId, status])
  @@map("event_participants")
}

// ============================================================================
// Module 5: 掲示板
// ============================================================================

model BoardPost {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId     String?   @map("category_id") @db.Uuid
  authorUserId   String    @map("author_user_id") @db.Uuid
  title          String    @db.VarChar(200)
  body           String
  isPinned       Boolean   @default(false) @map("is_pinned")
  viewCount      Int       @default(0) @map("view_count")
  commentCount   Int       @default(0) @map("comment_count")
  likeCount      Int       @default(0) @map("like_count")
  viewPermission String    @default("all") @map("view_permission") @db.VarChar(20)
  requiredRankId String?   @map("required_rank_id") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz

  category     Category?       @relation(fields: [categoryId], references: [id])
  author       User            @relation(fields: [authorUserId], references: [id])
  requiredRank MemberRank?     @relation("BoardPostRequiredRank", fields: [requiredRankId], references: [id])
  images       BoardPostImage[]
  tags         BoardPostTag[]
  comments     BoardComment[]

  @@index([isPinned(sort: Desc), createdAt(sort: Desc)])
  @@index([categoryId, createdAt(sort: Desc)])
  @@index([authorUserId])
  @@map("board_posts")
}

model BoardPostImage {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  fileId    String   @map("file_id") @db.Uuid
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  post BoardPost @relation(fields: [postId], references: [id])
  file File      @relation(fields: [fileId], references: [id])

  @@index([postId, sortOrder])
  @@map("board_post_images")
}

model BoardPostTag {
  postId String @map("post_id") @db.Uuid
  tagId  String @map("tag_id") @db.Uuid

  post BoardPost @relation(fields: [postId], references: [id])
  tag  Tag       @relation(fields: [tagId], references: [id])

  @@id([postId, tagId])
  @@index([tagId])
  @@map("board_post_tags")
}

model BoardComment {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  postId          String    @map("post_id") @db.Uuid
  authorUserId    String    @map("author_user_id") @db.Uuid
  parentCommentId String?   @map("parent_comment_id") @db.Uuid
  body            String
  likeCount       Int       @default(0) @map("like_count")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz

  post          BoardPost     @relation(fields: [postId], references: [id])
  author        User          @relation(fields: [authorUserId], references: [id])
  parentComment BoardComment? @relation("CommentReplies", fields: [parentCommentId], references: [id])
  replies       BoardComment[] @relation("CommentReplies")

  @@index([postId, createdAt])
  @@index([authorUserId])
  @@index([parentCommentId])
  @@map("board_comments")
}

model BoardLike {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  targetType String   @map("target_type") @db.VarChar(20)
  targetId   String   @map("target_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, targetType, targetId])
  @@index([targetType, targetId])
  @@map("board_likes")
}

// ============================================================================
// Module 6: 動画
// ============================================================================

model Video {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId      String?   @map("category_id") @db.Uuid
  title           String    @db.VarChar(200)
  description     String?
  videoUrl        String    @map("video_url") @db.VarChar(500)
  thumbnailUrl    String?   @map("thumbnail_url") @db.VarChar(500)
  durationSeconds Int?      @map("duration_seconds")
  viewPermission  String    @default("all") @map("view_permission") @db.VarChar(20)
  requiredRankId  String?   @map("required_rank_id") @db.Uuid
  isPublished     Boolean   @default(false) @map("is_published")
  sortOrder       Int       @default(0) @map("sort_order")
  viewCount       Int       @default(0) @map("view_count")
  createdByUserId String    @map("created_by_user_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz

  category       Category?           @relation(fields: [categoryId], references: [id])
  requiredRank   MemberRank?         @relation("VideoRequiredRank", fields: [requiredRankId], references: [id])
  createdBy      User                @relation(fields: [createdByUserId], references: [id])
  watchProgress  VideoWatchProgress[]
  tasks          VideoTask[]

  @@index([isPublished, sortOrder])
  @@index([categoryId])
  @@index([createdByUserId])
  @@map("videos")
}

model VideoWatchProgress {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  videoId             String    @map("video_id") @db.Uuid
  userId              String    @map("user_id") @db.Uuid
  watchedSeconds      Int       @default(0) @map("watched_seconds")
  totalSeconds        Int       @default(0) @map("total_seconds")
  isCompleted         Boolean   @default(false) @map("is_completed")
  lastPositionSeconds Int       @default(0) @map("last_position_seconds")
  completedAt         DateTime? @map("completed_at") @db.Timestamptz
  lastWatchedAt       DateTime? @map("last_watched_at") @db.Timestamptz
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  video Video @relation(fields: [videoId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([videoId, userId])
  @@index([userId])
  @@map("video_watch_progress")
}

model VideoTask {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  videoId     String   @map("video_id") @db.Uuid
  title       String   @db.VarChar(200)
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  video       Video                 @relation(fields: [videoId], references: [id])
  completions VideoTaskCompletion[]

  @@index([videoId, sortOrder])
  @@map("video_tasks")
}

model VideoTaskCompletion {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  videoTaskId String   @map("video_task_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  completedAt DateTime @default(now()) @map("completed_at") @db.Timestamptz
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  videoTask VideoTask @relation(fields: [videoTaskId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@unique([videoTaskId, userId])
  @@index([userId])
  @@map("video_task_completions")
}

// ============================================================================
// Module 7: チャット
// ============================================================================

model ChatRoom {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type          String    @db.VarChar(10)
  name          String?   @db.VarChar(100)
  lastMessageAt DateTime? @map("last_message_at") @db.Timestamptz
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  members  ChatRoomMember[]
  messages ChatMessage[]

  @@index([lastMessageAt(sort: Desc)])
  @@map("chat_rooms")
}

model ChatRoomMember {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chatRoomId String    @map("chat_room_id") @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  lastReadAt DateTime? @map("last_read_at") @db.Timestamptz
  isMuted    Boolean   @default(false) @map("is_muted")
  joinedAt   DateTime  @default(now()) @map("joined_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  chatRoom ChatRoom @relation(fields: [chatRoomId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@unique([chatRoomId, userId])
  @@index([userId])
  @@map("chat_room_members")
}

model ChatMessage {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chatRoomId   String    @map("chat_room_id") @db.Uuid
  senderUserId String    @map("sender_user_id") @db.Uuid
  messageType  String    @default("text") @map("message_type") @db.VarChar(10)
  body         String?
  fileId       String?   @map("file_id") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz

  chatRoom ChatRoom @relation(fields: [chatRoomId], references: [id])
  sender   User     @relation(fields: [senderUserId], references: [id])
  file     File?    @relation(fields: [fileId], references: [id])

  @@index([chatRoomId, createdAt])
  @@index([senderUserId])
  @@map("chat_messages")
}

// ============================================================================
// Module 8: メール配信
// ============================================================================

model MailTemplate {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @db.VarChar(100)
  subject   String   @db.VarChar(200)
  bodyHtml  String   @map("body_html")
  bodyText  String?  @map("body_text")
  variables Json?    @db.JsonB
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  campaigns MailCampaign[]

  @@map("mail_templates")
}

model MailCampaign {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  templateId      String?   @map("template_id") @db.Uuid
  subject         String    @db.VarChar(200)
  bodyHtml        String    @map("body_html")
  bodyText        String?   @map("body_text")
  targetType      String    @map("target_type") @db.VarChar(20)
  targetFilter    Json?     @map("target_filter") @db.JsonB
  status          String    @default("draft") @db.VarChar(20)
  scheduledAt     DateTime? @map("scheduled_at") @db.Timestamptz
