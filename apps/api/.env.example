# ============================================
# Community Platform - API (.env)
# ============================================

# --- App ---
NODE_ENV=development
PORT=4000

# --- Database (Supabase PostgreSQL) ---
# DATABASE_URL: pgbouncer 経由（ポート 6543, pgbouncer=true）
# DIRECT_URL: 直接接続（ポート 5432）— マイグレーション・シード用
DATABASE_URL=postgresql://postgres:password@localhost:5432/community_platform
DIRECT_URL=postgresql://postgres:password@localhost:5432/community_platform

# --- Redis ---
# チャット WebSocket（将来の Redis Adapter）、BullMQ ジョブキュー用
# ローカル: Docker Compose で起動、本番: Railway 等のマネージド Redis
REDIS_URL=redis://localhost:6379

# --- JWT ---
JWT_SECRET=your-jwt-secret-key-at-least-32-characters-long
JWT_REFRESH_SECRET=your-refresh-secret-key-at-least-32-characters-long
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# --- CORS ---
# フロントエンドのオリジン（WebSocket の CORS にも使用）
CORS_ORIGIN=http://localhost:3000

# --- Sentry (optional) ---
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_AUTH_TOKEN=

# --- Resend (optional) ---
# 未設定時はメール送信をモック（コンソール出力のみ）
# RESEND_API_KEY=re_xxxxxxxxxx

# --- Storage: Cloudflare R2 or MinIO ---
# ローカル開発: MinIO（Docker Compose で起動）
S3_ENDPOINT=http://localhost:9000
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_BUCKET_NAME=community-files-dev
R2_PUBLIC_URL=http://localhost:9000/community-files-dev

# 本番: Cloudflare R2（S3_ENDPOINT を削除して以下を設定）
# CLOUDFLARE_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=community-files-prod
# R2_PUBLIC_URL=https://pub-xxxx.r2.dev
