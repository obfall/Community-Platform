# ============================================
# Community Platform - API (.env)
# ============================================

# --- App ---
NODE_ENV=development
PORT=4000

# --- Database (Supabase PostgreSQL) ---
DATABASE_URL=postgresql://postgres:password@localhost:5432/community_platform
DIRECT_URL=postgresql://postgres:password@localhost:5432/community_platform

# --- Redis (Railway / Local) ---
# Optional in Phase 0, required from Phase 3
REDIS_URL=redis://localhost:6379

# --- JWT ---
JWT_SECRET=your-jwt-secret-key-at-least-32-characters-long
JWT_REFRESH_SECRET=your-refresh-secret-key-at-least-32-characters-long
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# --- CORS ---
CORS_ORIGIN=http://localhost:3000

# --- Sentry (optional) ---
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_AUTH_TOKEN=
